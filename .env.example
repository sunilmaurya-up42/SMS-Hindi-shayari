# ======================================
# Application
# ======================================

NODE_ENV=development
PORT=5000
SITE_URL=http://localhost:5000

# ======================================
# MongoDB
# ======================================

MONGODB_URI=mongodb://127.0.0.1:27017/sms_hindi_shayari

# ======================================
# Session
# ======================================

SESSION_SECRET=change_this_to_a_secure_random_string

# ======================================
# JWT
# ======================================

JWT_SECRET=change_this_to_a_secure_jwt_secret
JWT_EXPIRES_IN=7d

# ======================================
# Admin Account
# ======================================

ADMIN_NAME=Administrator
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=StrongPassword123@

# ======================================
# GitHub Storage
# ======================================

GITHUB_OWNER=your_github_username
GITHUB_REPO=SMS-Hindi-shayari
GITHUB_BRANCH=main
GITHUB_TOKEN=your_github_personal_access_token

# ======================================
# Google OAuth
# ======================================

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# ======================================
# Email (SMTP)
# ======================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="SMS Hindi Shayari <no-reply@example.com>"

# ======================================
# Cloudinary (Optional)
# ======================================

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ======================================
# Google Analytics
# ======================================

GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# ======================================
# Google AdSense
# ======================================

ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX

# ======================================
# Security
# ======================================

BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# ======================================
# File Upload
# ======================================

MAX_FILE_SIZE=5242880
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif

# ======================================
# Logging
# ======================================

LOG_LEVEL=info

<h1 class="mb-4">Admin Dashboard</h1>

<div class="row">

    <div class="col-md-3 mb-3">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <h2><%= stats.users %></h2>
                <p>Total Users</p>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <h2><%= stats.shayaries %></h2>
                <p>Total Shayari</p>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <h2><%= stats.categories %></h2>
                <p>Categories</p>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <h2><%= stats.contacts %></h2>
                <p>New Contacts</p>
            </div>
        </div>
    </div>

</div>

<hr>

<div class="list-group">

    <a href="/admin/shayari" class="list-group-item list-group-item-action">
        📖 Manage Shayari
    </a>

    <a href="/admin/category" class="list-group-item list-group-item-action">
        📂 Manage Categories
    </a>

    <a href="/admin/users" class="list-group-item list-group-item-action">
        👤 Users
    </a>

    <a href="/admin/contacts" class="list-group-item list-group-item-action">
        📩 Contact Messages
    </a>

    <a href="/admin/ai-images" class="list-group-item list-group-item-action">
        🖼 AI Images
    </a>

    <a href="/auth/logout" class="list-group-item list-group-item-action text-danger">
        🚪 Logout
    </a>

</div>

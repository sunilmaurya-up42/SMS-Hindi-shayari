<h1 class="mb-4">Upload Background Image</h1>

<form
    action="/admin/background/create"
    method="POST"
    enctype="multipart/form-data">

    <div class="mb-3">

        <label class="form-label">

            Title

        </label>

        <input
            type="text"
            name="title"
            class="form-control"
            required>

    </div>

    <div class="mb-4">

        <label class="form-label">

            Background Image

        </label>

        <input
            type="file"
            name="image"
            class="form-control"
            accept="image/*"
            required>

    </div>

    <button
        type="submit"
        class="btn btn-success">

        Upload

    </button>

    <a
        href="/admin/background"
        class="btn btn-secondary">

        Back

    </a>

</form>

<!-- =====================================
     Navbar Start
====================================== -->

<nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm sticky-top">

    <div class="container">

        <!-- Logo -->

        <a class="navbar-brand fw-bold" href="/">

            <i class="fa-solid fa-heart text-warning"></i>

            SMS Hindi Shayari

        </a>

        <!-- Mobile Toggle -->

        <button
            class="navbar-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#mainNavbar">

            <span class="navbar-toggler-icon"></span>

        </button>

        <div
            class="collapse navbar-collapse"
            id="mainNavbar">

            <!-- Left Menu -->

            <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                <li class="nav-item">

                    <a
                        class="nav-link <%= request && request.path==='/' ? 'active' : '' %>"
                        href="/">

                        Home

                    </a>

                </li>

                <li class="nav-item">

                    <a
                        class="nav-link"
                        href="/shayari">

                        All Shayari

                    </a>

                </li>

                <!-- Categories -->

                <li class="nav-item dropdown">

                    <a
                        class="nav-link dropdown-toggle"
                        href="#"
                        data-bs-toggle="dropdown">

                        Categories

                    </a>

                    <ul class="dropdown-menu">

                        <li>

                            <a
                                class="dropdown-item"
                                href="/category/love">

                                ❤️ Love Shayari

                            </a>

                        </li>

                        <li>

                            <a
                                class="dropdown-item"
                                href="/category/sad">

                                💔 Sad Shayari

                            </a>

                        </li>

                        <li>

                            <a
                                class="dropdown-item"
                                href="/category/attitude">

                                😎 Attitude Shayari

                            </a>

                        </li>

                        <li>

                            <a
                                class="dropdown-item"
                                href="/category/friendship">

                                🤝 Friendship Shayari

                            </a>

                        </li>

                        <li>

                            <a
                                class="dropdown-item"
                                href="/category/motivational">

                                🚀 Motivational

                            </a>

                        </li>

                        <li>

                            <hr class="dropdown-divider">

                        </li>

                        <li>

                            <a
                                class="dropdown-item"
                                href="/categories">

                                View All Categories

                            </a>

                        </li>

                    </ul>

                </li>

            </ul>
            <!-- Search Form -->

            <form
                class="d-flex mx-lg-3 my-3 my-lg-0"
                action="/search"
                method="GET">

                <div class="input-group">

                    <input
                        type="search"
                        class="form-control"
                        name="q"
                        placeholder="Search Shayari..."
                        value="<%= typeof query !== 'undefined' ? query : '' %>"
                        autocomplete="off">

                    <button
                        class="btn btn-warning"
                        type="submit">

                        <i class="fa-solid fa-search"></i>

                    </button>

                </div>

            </form>

            <!-- Right Menu -->

            <ul class="navbar-nav ms-auto align-items-lg-center">

                <% if(user){ %>

                <li class="nav-item">

                    <a
                        href="/favorites"
                        class="nav-link">

                        <i class="fa-solid fa-heart"></i>

                        Favorites

                    </a>

                </li>

                <li class="nav-item">

                    <a
                        href="/profile"
                        class="nav-link">

                        <i class="fa-solid fa-user"></i>

                        Profile

                    </a>

                </li>

                <% if(user.role==="admin"){ %>

                <li class="nav-item">

                    <a
                        href="/admin"
                        class="nav-link text-warning fw-semibold">

                        <i class="fa-solid fa-gauge-high"></i>

                        Admin

                    </a>

                </li>

                <% } %>

                <li class="nav-item dropdown">

                    <a
                        class="nav-link dropdown-toggle"
                        href="#"
                        data-bs-toggle="dropdown">

                        <img
                            src="<%= user.avatar || '/images/default-user.png' %>"
                            width="34"
                            height="34"
                            class="rounded-circle me-1"
                            alt="User">

                        <%= user.name %>

                    </a>

                    <ul
                        class="dropdown-menu dropdown-menu-end">

                        <li>

                            <a
                                class="dropdown-item"
                                href="/profile">

                                <i class="fa-solid fa-user me-2"></i>

                                My Profile

                            </a>

                        </li>

                        <li>

                            <a
                                class="dropdown-item"
                                href="/favorites">

                                <i class="fa-solid fa-heart me-2"></i>

                                Favorites

                            </a>

                        </li>

                        <li>

                            <a
                                class="dropdown-item"
                                href="/downloads">

                                <i class="fa-solid fa-download me-2"></i>

                                Downloads

                            </a>

                        </li>

                        <li>

                            <hr class="dropdown-divider">

                        </li>

                        <li>

                            <a
                                class="dropdown-item text-danger"
                                href="/auth/logout">

                                <i class="fa-solid fa-right-from-bracket me-2"></i>

                                Logout

                            </a>

                        </li>

                    </ul>

                </li>

                <% } else { %>

                <li class="nav-item">

                    <a
                        href="/auth/login"
                        class="nav-link">

                        Login

                    </a>

                </li>

                <li class="nav-item ms-lg-2">

                    <a
                        href="/auth/register"
                        class="btn btn-warning text-dark fw-semibold">

                        Register

                    </a>

                </li>

                <% } %>

            </ul>

        </div>

    </div>

</nav>

<!-- ===== Navbar End ===== -->


<!DOCTYPE html>
<html lang="en">

<head>

    <%- include("../partials/head") %>

</head>

<body>

<%- include("../partials/navbar") %>

<!-- ==================================
Search Header
================================== -->

<section class="bg-dark text-white py-5">

    <div class="container">

        <div class="row align-items-center">

            <div class="col-lg-8">

                <h1 class="display-5 fw-bold">

                    Search Hindi Shayari

                </h1>

                <p class="lead mb-0">

                    Find Love, Sad, Attitude, Friendship, Romantic,
                    Motivational and many more Hindi Shayari.

                </p>

            </div>

            <div class="col-lg-4">

                <form
                    action="/search"
                    method="GET">

                    <div class="input-group input-group-lg">

                        <input
                            type="text"
                            class="form-control"
                            name="q"
                            value="<%= keyword || '' %>"
                            placeholder="Search Shayari..."
                            required>

                        <button
                            class="btn btn-danger"
                            type="submit">

                            <i class="fa-solid fa-search"></i>

                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

</section>

<!-- ==================================
Breadcrumb
================================== -->

<section class="bg-light border-bottom">

    <div class="container py-3">

        <nav>

            <ol class="breadcrumb mb-0">

                <li class="breadcrumb-item">

                    <a href="/">

                        Home

                    </a>

                </li>

                <li class="breadcrumb-item active">

                    Search

                </li>

            </ol>

        </nav>

    </div>

</section>

<!-- ==================================
Search Results
================================== -->

<section class="py-5">

<div class="container">

<div class="d-flex justify-content-between align-items-center mb-4">

<h2 class="fw-bold">

Search Results

</h2>

<% if(keyword){ %>

<span class="badge bg-danger fs-6">

Keyword :
<%= keyword %>

</span>

<% } %>

</div>

<div class="row g-4">

<% if(shayari && shayari.length){ %>
<% shayari.forEach(function(item){ %>

<div class="col-lg-4 col-md-6">

<div class="card shadow-sm border-0 h-100">

<% if(item.background){ %>

<img
src="<%= item.background.rawUrl %>"
class="card-img-top"
alt="<%= item.title %>">

<% } %>

<div class="card-body">

<% if(shayari.category){ %>

<span class="badge bg-primary mb-2">

<%= shayari.category.name %>

</span>

<% } %>

<h4 class="fw-bold">

<%= shayari.title %>

</h4>

<p class="text-muted">

<%= shayari.excerpt %>

</p>

</div>

<div class="card-footer bg-white border-0 d-flex justify-content-between align-items-center">

<a
href="/shayari/<%= shayari.slug %>"
class="btn btn-danger">

Read More

</a>

<small class="text-muted">

👁 <%= shayari.views %>

</small>

</div>

</div>

</div>

<% }) %>

<% } else { %>

<% if(query){ %>

<div class="col-12">

<div class="alert alert-warning">

No Shayari found for

<strong>

"<%= query %>"

</strong>

Try another keyword.

</div>

</div>

<% } else { %>

<div class="col-12">

<div class="alert alert-info">

Search for your favourite Hindi Shayari using the search box above.

</div>

</div>

<% } %>

<div class="col-md-4">

<div class="card shadow-sm border-0 h-100">

<div class="card-body text-center">

<div class="display-4 mb-3">

❤️

</div>

<h5>

Love Shayari

</h5>

<a
href="/category/love"
class="btn btn-outline-danger mt-2">

Browse

</a>

</div>

</div>

</div>

<div class="col-md-4">

<div class="card shadow-sm border-0 h-100">

<div class="card-body text-center">

<div class="display-4 mb-3">

💔

</div>

<h5>

Sad Shayari

</h5>

<a
href="/category/sad"
class="btn btn-outline-primary mt-2">

Browse

</a>

</div>

</div>

</div>

<div class="col-md-4">

<div class="card shadow-sm border-0 h-100">

<div class="card-body text-center">

<div class="display-4 mb-3">

😎

</div>

<h5>

Attitude Shayari

</h5>

<a
href="/category/attitude"
class="btn btn-outline-dark mt-2">

Browse

</a>

</div>

</div>

</div>

<% } %>

</div>

</div>

</section>

<!-- ==================================
Popular Searches
================================== -->

<section class="py-5 bg-light">

<div class="container">

<h2 class="fw-bold mb-4">

Popular Searches

</h2>

<div class="d-flex flex-wrap gap-2">

<a href="/search?q=love" class="btn btn-outline-danger">

Love Shayari

</a>

<a href="/search?q=sad" class="btn btn-outline-secondary">

Sad Shayari

</a>

<a href="/search?q=attitude" class="btn btn-outline-dark">

Attitude Shayari

</a>

<a href="/search?q=friendship" class="btn btn-outline-success">

Friendship Shayari

</a>

<a href="/search?q=motivational" class="btn btn-outline-primary">

Motivational Shayari

</a>

<a href="/search?q=romantic" class="btn btn-outline-warning">

Romantic Shayari

</a>

</div>

</div>

</section>

<!-- ==================================
SEO Content
================================== -->

<section class="py-5">

    <div class="container">

        <div class="row justify-content-center">

            <div class="col-lg-10">

                <h2 class="fw-bold mb-4">

                    Search Hindi Shayari Online

                </h2>

                <p class="text-muted">

                    Search thousands of Hindi Shayari including Love Shayari,
                    Sad Shayari, Friendship Shayari, Romantic Shayari,
                    Attitude Shayari, Motivational Shayari, Good Morning
                    Shayari, Good Night Shayari and many more.

                </p>

                <p class="text-muted">

                    SMS Hindi Shayari provides fast search, beautiful AI
                    background images, easy sharing, copy text, favorites,
                    downloads and a responsive experience on all devices.

                </p>

            </div>

        </div>

    </div>

</section>

<!-- ==================================
Explore Categories
================================== -->

<section class="py-5 bg-light">

    <div class="container">

        <h2 class="text-center fw-bold mb-5">

            Explore Categories

        </h2>

        <div class="row g-3">

            <div class="col-md-3">

                <a
                    href="/category/love"
                    class="btn btn-outline-danger w-100">

                    ❤️ Love

                </a>

            </div>

            <div class="col-md-3">

                <a
                    href="/category/sad"
                    class="btn btn-outline-primary w-100">

                    💔 Sad

                </a>

            </div>

            <div class="col-md-3">

                <a
                    href="/category/attitude"
                    class="btn btn-outline-dark w-100">

                    😎 Attitude

                </a>

            </div>

            <div class="col-md-3">

                <a
                    href="/category/friendship"
                    class="btn btn-outline-success w-100">

                    🤝 Friendship

                </a>

            </div>

        </div>

    </div>

</section>

<!-- ==================================
Footer
================================== -->

<%- include("../partials/footer") %>

<!-- ==================================
Scripts
================================== -->

<%- include("../partials/scripts") %>

</body>

</html>

<div class="container">

<div class="d-flex justify-content-between align-items-center mb-4">

<h2 class="fw-bold">

Popular Categories

</h2>

<a
href="/shayari"
class="btn btn-outline-primary">

View All

</a>

</div>

<div class="row g-4">

<div class="col-md-4">

<a
href="/category/love"
class="text-decoration-none">

<div class="card shadow-sm h-100">

<div class="card-body text-center">

<div class="display-5 mb-3">

❤️

</div>

<h4>

Love Shayari

</h4>

<p class="text-muted">

Beautiful Romantic Hindi Shayari.

</p>

</div>

</div>

</a>

</div>

<div class="col-md-4">

<a
href="/category/sad"
class="text-decoration-none">

<div class="card shadow-sm h-100">

<div class="card-body text-center">

<div class="display-5 mb-3">

💔

</div>

<h4>

Sad Shayari

</h4>

<p class="text-muted">

Heart Touching Sad Shayari.

</p>

</div>

</div>

</a>

</div>

<div class="col-md-4">

<a
href="/category/attitude"
class="text-decoration-none">

<div class="card shadow-sm h-100">

<div class="card-body text-center">

<div class="display-5 mb-3">

😎

</div>

<h4>

Attitude Shayari

</h4>

<p class="text-muted">

Royal & Killer Attitude Shayari.

</p>

</div>

</div>

</a>

</div>

</div>

</div>

</section>
<!-- ==================================
Latest Shayari
================================== -->

<section class="py-5 bg-body-tertiary">

    <div class="container">

        <div class="d-flex justify-content-between align-items-center mb-4">

            <h2 class="fw-bold">

                Latest Shayari

            </h2>

            <a
                href="/shayari"
                class="btn btn-outline-danger">

                View All

            </a>

        </div>

        <div class="row g-4">

            <% if(typeof shayaries !== "undefined" && shayaries.length){ %>

                <% shayaries.forEach(item=>{ %>

                <div class="col-lg-4 col-md-6">

                    <div class="card h-100 shadow-sm">

                        <% if(item.thumbnail){ %>

                        <img
                            src="<%= item.thumbnail %>"
                            class="card-img-top"
                            alt="<%= item.title %>">

                        <% } %>

                        <div class="card-body">

                            <h5 class="card-title">

                                <%= item.title %>

                            </h5>

                            <p class="text-muted">

                                <%= item.excerpt %>

                            </p>

                        </div>

                        <div class="card-footer bg-white border-0">

                            <a
                                href="/shayari/<%= item.slug %>"
                                class="btn btn-danger btn-sm">

                                Read More

                            </a>

                        </div>

                    </div>

                </div>

                <% }) %>

            <% }else{ %>

                <% for(let i=1;i<=6;i++){ %>

                <div class="col-lg-4 col-md-6">

                    <div class="card shadow-sm h-100">

                        <div class="card-body">

                            <span class="badge bg-danger">

                                Demo

                            </span>

                            <h5 class="mt-3">

                                Beautiful Hindi Shayari <%= i %>

                            </h5>

                            <p class="text-muted">

                                Your latest published Shayari will automatically appear here.

                            </p>

                            <a
                                href="/shayari"
                                class="btn btn-outline-primary btn-sm">

                                Explore

                            </a>

                        </div>

                    </div>

                </div>

                <% } %>

            <% } %>

        </div>

    </div>

</section>


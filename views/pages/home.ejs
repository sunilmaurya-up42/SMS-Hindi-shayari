<body>



<!-- ==================================
Hero Section
================================== -->

<section class="py-5 bg-light border-bottom">

    <div class="container">

        <div class="row align-items-center">

            <div class="col-lg-6">

                <span class="badge bg-danger mb-3">

                    ❤️ India's Best Hindi Shayari Collection

                </span>

                <h1 class="display-4 fw-bold mb-3">

                    SMS Hindi Shayari

                </h1>

                <p class="lead text-muted">

                    Love Shayari, Sad Shayari, Attitude Shayari,
                    Friendship Shayari, Motivational Shayari,
                    Romantic Shayari, Festival Shayari,
                    Good Morning & Good Night Shayari.

                </p>

                <form
                    action="/search"
                    method="GET"
                    class="mt-4">

                    <div class="input-group input-group-lg">

                        <input
                            type="text"
                            name="q"
                            class="form-control"
                            placeholder="Search Shayari...">

                        <button
                            class="btn btn-danger"
                            type="submit">

                            <i class="fa-solid fa-search"></i>

                            Search

                        </button>

                    </div>

                </form>

            </div>

            <div class="col-lg-6 text-center">

                <img
                    src="/images/hero.png"
                    class="img-fluid"
                    alt="SMS Hindi Shayari">

            </div>

        </div>

    </div>

</section>


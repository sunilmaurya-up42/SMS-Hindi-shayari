<!DOCTYPE html>
<html lang="en">

<head>

    <%- include("../../partials/head") %>

</head>

<body>

<%- include("../../partials/navbar") %>

<!-- ==================================
Category Header
================================== -->

<section class="bg-primary text-white py-5">

    <div class="container">

        <div class="row align-items-center">

            <div class="col-lg-8">

                <h1 class="display-5 fw-bold">

                    <%= category.name %>

                </h1>

                <p class="lead mb-0">

                    <%= category.description || "Read the latest Hindi Shayari from this category." %>

                </p>

            </div>

            <div class="col-lg-4">

                <form
                    action="/search"
                    method="GET">

                    <div class="input-group">

                        <input
                            type="text"
                            name="q"
                            class="form-control form-control-lg"
                            placeholder="Search Shayari...">

                        <button
                            class="btn btn-dark"
                            type="submit">

                            <i class="fa-solid fa-search"></i>

                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

</section>

<!-- ==================================
Breadcrumb
================================== -->

<section class="bg-light border-bottom">

    <div class="container py-3">

        <nav>

            <ol class="breadcrumb mb-0">

                <li class="breadcrumb-item">

                    <a href="/">

                        Home

                    </a>

                </li>

                <li class="breadcrumb-item">

                    <a href="/shayari">

                        Shayari

                    </a>

                </li>

                <li class="breadcrumb-item active">

                    <%= category.name %>

                </li>

            </ol>

        </nav>

    </div>

</section>

<!-- ==================================
Category Shayari List
================================== -->

<section class="py-5">

<div class="container">

<div class="row g-4">

<% if(shayari && shayari.length){ %>

<% shayari.forEach(function(item){ %>

<div class="col-lg-4 col-md-6">

<div class="card shadow-sm border-0 h-100">

<% if(item.background){ %>

<img
src="<%= item.background.rawUrl %>"
class="card-img-top"
alt="<%= item.title %>"
<% } %>

<div class="card-body">

<h4 class="fw-bold">

<%= item.title %>

</h4>

<p class="text-muted">

<%= item.excerpt || item.content.substring(0, 120) %>

</p>

</div>

<div class="card-footer bg-white border-0 d-flex justify-content-between align-items-center">

<a
href="/shayari/<%= item.slug %>"
class="btn btn-primary">

Read More

</a>

<small class="text-muted">

👁 <%= item.views || 0 %>

</small>

</div>

</div>

</div>

<% }) %>

<% } else { %>

<% for(let i=1;i<=6;i++){ %>

<div class="col-lg-4 col-md-6">

<div class="card shadow-sm border-0 h-100">

<div class="card-body">

<span class="badge bg-secondary mb-2">

Demo

</span>

<h4 class="fw-bold">

Beautiful Hindi Shayari <%= i %>

</h4>

<p class="text-muted">

This category doesn't have any Shayari yet.

</p>

<a
href="/shayari"
class="btn btn-outline-primary">

Browse All

</a>

</div>

</div>

</div>

<% } %>

<% } %>

</div>

<!-- ==================================
Pagination
================================== -->

<% if(pagination && pagination.pages > 1){ %>

<nav class="mt-5">

<ul class="pagination justify-content-center">

<li class="page-item <%= pagination.page <= 1 ? 'disabled' : '' %>">

<a
class="page-link"
href="?page=<%= pagination.page - 1 %>"

Previous

</a>

</li>

<li class="page-item active">

<span class="page-link">

<%= pagination.page %>

</span>

</li>

<li class="page-item <%= pagination.page >= pagination.pages ? 'disabled' : '' %>">

<a
class="page-link"
href="?page=<%= pagination.page + 1 %>"
Next

</a>

</li>

</ul>

</nav>

<% } %>

</div>

</section>

<!-- ==================================
Category Information
================================== -->

<section class="py-5 bg-light">

<div class="container">

<div class="row">

<div class="col-lg-8">

<h2 class="fw-bold">

About <%= category.name %>

</h2>

<p class="text-muted">

<%= category.description || "Browse the latest collection of Hindi Shayari in this category. Every Shayari is updated regularly with beautiful backgrounds and easy sharing options." %>

</p>

</div>

<div class="col-lg-4">

<div class="card shadow-sm border-0">

<div class="card-header bg-primary text-white">

Popular Categories

</div>

<div class="list-group list-group-flush">

<a
href="/category/love"
class="list-group-item">

❤️ Love Shayari

</a>

<a
href="/category/sad"
class="list-group-item">

💔 Sad Shayari

</a>

<a
href="/category/attitude"
class="list-group-item">

😎 Attitude Shayari

</a>

<a
href="/category/friendship"
class="list-group-item">

🤝 Friendship Shayari

</a>

<a
href="/category/motivational"
class="list-group-item">

🚀 Motivational Shayari

</a>

</div>

</div>

</div>

</div>

</div>

</section>

<!-- ==================================
SEO Content
================================== -->

<section class="py-5">

    <div class="container">

        <div class="row justify-content-center">

            <div class="col-lg-10">

                <h2 class="fw-bold mb-4">

                    <%= category.name %> Hindi Shayari

                </h2>

                <p class="text-muted">

                    Read the latest <%= category.name %> Hindi Shayari collection.
                    Every Shayari is selected carefully and updated regularly so you
                    always get fresh content for reading, sharing and downloading.

                </p>

                <p class="text-muted">

                    SMS Hindi Shayari provides beautiful Shayari with AI generated
                    backgrounds, copy option, social sharing, image download and a
                    mobile friendly reading experience.

                </p>

            </div>

        </div>

    </div>

</section>

<!-- ==================================
Explore More Categories
================================== -->

<section class="py-5 bg-light">

    <div class="container">

        <h2 class="text-center fw-bold mb-5">

            Explore More Categories

        </h2>

        <div class="row g-3">

            <div class="col-md-3">

                <a
                    href="/category/love"
                    class="btn btn-outline-danger w-100">

                    ❤️ Love

                </a>

            </div>

            <div class="col-md-3">

                <a
                    href="/category/sad"
                    class="btn btn-outline-primary w-100">

                    💔 Sad

                </a>

            </div>

            <div class="col-md-3">

                <a
                    href="/category/attitude"
                    class="btn btn-outline-dark w-100">

                    😎 Attitude

                </a>

            </div>

            <div class="col-md-3">

                <a
                    href="/category/friendship"
                    class="btn btn-outline-success w-100">

                    🤝 Friendship

                </a>

            </div>

        </div>

    </div>

</section>

<!-- ==================================
Footer
================================== -->

<%- include("../../partials/footer") %>

<!-- ==================================
Scripts
================================== -->

<%- include("../../partials/scripts") %>

</body>

</html>
